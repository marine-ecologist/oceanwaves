library(sf)
library(tidyverse)
library(ggplot2)
### download GBR shape file
gbr_shape <- download_gbr_spatial(return = "base") |>
select(LOC_NAME_S, X_COORD, Y_COORD) |>
st_make_valid() |>
st_transform(20353)
}
### Grep subset of reefs for aves
whitsundays <- gbr_shape |>
filter(grepl("Hook|Hayman|reef", LOC_NAME_S)) |>
filter(grepl("20", LOC_NAME_S))
ggplot() + theme_bw() +
geom_sf(data=whitsundays, aes(fill=LOC_NAME_S), show.legend=FALSE)
whitsundays_weather <- readRDS("/Users/rof011/oceanwaves/data/shutedata.csv") |>
mutate(time = lubridate::ymd_hms(time)) |>
mutate(year=year(time)) |>
mutate(day=day(time)) |>
group_by(day) |>
summarise(windspeed_max = max(windspeed_ms))
whitsundays_weather <- readRDS("/Users/rof011/oceanwaves/data/shutedata.csv") |>
mutate(time = lubridate::ymd_hms(time)) |>
mutate(year=year(time)) |>
mutate(day=day(time)) |>
group_by(day) |>
summarise(windspeed_max = max(windspeed_ms))
library(oceanwaves)
library(dhw)
library(sf)
library(tidyverse)
library(ggplot2)
### download GBR shape file
gbr_shape <- download_gbr_spatial(return = "base") |>
select(LOC_NAME_S, X_COORD, Y_COORD) |>
st_make_valid() |>
st_transform(20353)
}
### Grep subset of reefs for aves
whitsundays <- gbr_shape |>
filter(grepl("Hook|Hayman|reef", LOC_NAME_S)) |>
filter(grepl("20", LOC_NAME_S))
ggplot() + theme_bw() +
geom_sf(data=whitsundays, aes(fill=LOC_NAME_S), show.legend=FALSE)
ggplot() + theme_bw() +
facet_wrap(~year, ncol=1, scales="free") +
geom_line(data = whitsundays_weather, aes(time, windspeed_max), linewidth=0.05)
### extract broader region for fetch (50km from focus reefs)
whitsundays_region <- st_crop(gbr_shape,
whitsundays |>
st_union() |>
st_centroid() |>
st_buffer(20000))
### create outline of reefs boundaries
whitsundays_union <- whitsundays |>
st_union() |>
st_boundary() |>
st_cast("LINESTRING")
ggplot() + theme_bw() +
geom_sf(data=whitsundays_region) +
geom_sf(data=whitsundays, aes(fill=LOC_NAME_S), show.legend=FALSE)
